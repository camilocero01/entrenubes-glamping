---
const whatsappLink = 'https://wa.me/573122941890?text=Hola%2C%20quiero%20reservar%20en%20Entrenubes%20Glamping';
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Video background -->
  <div class="absolute inset-0">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      class="absolute inset-0 w-full h-full object-cover"
      poster="https://images.unsplash.com/photo-1534274988757-a28bf1a57c17?w=1920&q=80" 
    >
      <source src="https://videos.pexels.com/video-files/5865939/5865939-hd_1920_1080_30fps.mp4" type="video/mp4" />
    </video>
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-primary/70 via-primary/50 to-primary/80">y</div>
    <!-- Animated cloud layers -->
    <div class="absolute inset-0 opacity-20">
      <div class="cloud cloud-1"></div>
      <div class="cloud cloud-2"></div>
      <div class="cloud cloud-3"></div> 
    </div>
    <!-- Bottom fade to white -->
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
    <div class="mb-6 fade-up">
      <span class="inline-block text-gold/90 text-sm md:text-base font-medium tracking-[0.35em] uppercase mb-4">
        Granada, Antioquia &middot; Colombia
      </span>
    </div>

    <h1 class="text-5xl md:text-7xl lg:text-8xl font-heading font-bold text-white mb-6 leading-tight text-shadow-lg fade-up">
      Despierta<br />
      <span class="italic text-gold">entre las nubes.</span>
    </h1>

    <p class="text-lg md:text-xl text-white/85 max-w-2xl mx-auto mb-10 leading-relaxed fade-up">
      En la cima de una montaña, donde el valle se cubre de nubes
      y cada amanecer se convierte en un espectáculo celestial.
      Vive una experiencia que toca el cielo.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 fade-up">
      <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-primary text-lg group">
        <svg class="w-6 h-6 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Reserva tu experiencia
      </a>
      <a href="#alojamientos" class="btn-outline text-lg">
        Ver alojamientos
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-8 h-8 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<style>
  .cloud {
    position: absolute;
    background: radial-gradient(ellipse, rgba(255,255,255,0.15) 0%, transparent 70%);
    border-radius: 50%;
  }
  .cloud-1 {
    width: 600px; height: 200px;
    top: 20%; left: -10%;
    animation: float-cloud 25s ease-in-out infinite;
  }
  .cloud-2 {
    width: 500px; height: 180px;
    top: 40%; right: -15%;
    animation: float-cloud 30s ease-in-out infinite reverse;
  }
  .cloud-3 {
    width: 700px; height: 220px;
    bottom: 25%; left: 20%;
    animation: float-cloud 35s ease-in-out infinite;
  }
  @keyframes float-cloud {
    0%, 100% { transform: translateX(0) translateY(0); opacity: 0.3; }
    25% { transform: translateX(40px) translateY(-10px); opacity: 0.5; }
    50% { transform: translateX(80px) translateY(5px); opacity: 0.3; }
    75% { transform: translateX(40px) translateY(-5px); opacity: 0.5; }
  }
</style>
