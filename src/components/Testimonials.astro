---
const testimonials = [
  {
    name: 'Carolina M.',
    location: 'Medellín',
    text: 'Fue la experiencia más mágica que hemos vivido. Despertar y ver todo el valle cubierto de nubes fue algo que jamás olvidaremos. El domo es increíblemente cómodo y la vista es de otro mundo.',
    rating: 5,
  },
  {
    name: 'Andrés & Juliana',
    location: 'Bogotá',
    text: 'Buscábamos un lugar especial para nuestro aniversario y Entrenubes superó todas las expectativas. La tranquilidad, el paisaje y la atención al detalle hacen de este lugar un verdadero paraíso.',
    rating: 5,
  },
  {
    name: 'Familia García',
    location: 'Envigado',
    text: 'La cabaña es perfecta para familias. Los niños disfrutaron de las cuatrimotos y nosotros del paisaje. Sin duda volveremos. Un 10/10 en todo.',
    rating: 5,
  },
];
---

<section id="testimonios" class="section-padding bg-white">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16 fade-up">
      <span class="text-secondary text-sm font-semibold tracking-[0.25em] uppercase mb-4 block">
        Testimonios
      </span>
      <h2 class="section-title">
        Lo que dicen<br />
        <span class="italic text-secondary">nuestros huéspedes</span>
      </h2>
    </div>

    <!-- Testimonial cards -->
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((t, i) => (
        <div class="bg-light rounded-3xl p-8 relative fade-up" style={`transition-delay: ${i * 150}ms`}>
          <!-- Quote icon -->
          <svg class="w-10 h-10 text-secondary/20 mb-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
          </svg>

          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <p class="text-primary/75 leading-relaxed mb-6 italic">"{t.text}"</p>

          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-secondary/20 flex items-center justify-center">
              <span class="text-secondary font-bold text-sm">{t.name.charAt(0)}</span>
            </div>
            <div>
              <p class="font-semibold text-primary text-sm">{t.name}</p>
              <p class="text-primary/50 text-xs">{t.location}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
