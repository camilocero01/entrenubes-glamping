---
const whatsappBase = 'https://wa.me/573122941890?text=';

const accommodations = [
  {
    name: 'Glamping Domo 1',
    tagline: 'Tu burbuja entre las nubes',
    description: 'Un domo geodésico transparente que te permite dormir bajo las estrellas y despertar con la vista más impresionante del valle. Diseñado para parejas que buscan una escapada romántica e inolvidable.',
    features: ['Vista panorámica 360°', 'Cama doble premium', 'Baño privado', 'Terraza privada', 'Calefacción'],
    capacity: '2 personas',
    whatsapp: whatsappBase + encodeURIComponent('Hola, quiero reservar el Glamping Domo 1'),
    image: 'https://images.unsplash.com/photo-1631635589499-afd87d52bf64?w=800&q=80',
    imageAlt: 'Glamping Domo 1 - Domo geodésico con vista panorámica al valle',
  },
  {
    name: 'Glamping Domo 2',
    tagline: 'Donde el cielo es tu techo',
    description: 'Nuestro segundo domo geodésico, con una ubicación privilegiada que ofrece vistas al amanecer. Perfecto para quienes desean sumergirse en la naturaleza sin perder la comodidad de un alojamiento premium.',
    features: ['Vista al amanecer', 'Cama doble premium', 'Baño privado', 'Zona de fogata', 'Minibar'],
    capacity: '2 personas',
    whatsapp: whatsappBase + encodeURIComponent('Hola, quiero reservar el Glamping Domo 2'),
    image: 'https://images.unsplash.com/photo-1682695796954-bad0d0f59ff1?w=800&q=80',
    imageAlt: 'Glamping Domo 2 - Domo geodésico con vista al amanecer',
  },
  {
    name: 'Glamping Cabaña',
    tagline: 'Refugio acogedor en la montaña',
    description: 'Una cabaña rústica con acabados en madera natural, perfecta para familias o grupos pequeños. Combina la calidez de la montaña con todas las comodidades modernas para una estadía perfecta.',
    features: ['Construcción en madera', 'Sala con chimenea', 'Cocina equipada', 'Terraza con hamacas', 'Capacidad familiar'],
    capacity: '4-6 personas',
    whatsapp: whatsappBase + encodeURIComponent('Hola, quiero reservar la Glamping Cabaña'),
    image: 'https://images.unsplash.com/photo-1587061949409-02df41d5e562?w=800&q=80',
    imageAlt: 'Glamping Cabaña - Cabaña de madera en la montaña',
  },
];
---

<section id="alojamientos" class="section-padding bg-light">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16 fade-up">
      <span class="text-secondary text-sm font-semibold tracking-[0.25em] uppercase mb-4 block">
        Alojamientos
      </span>
      <h2 class="section-title">
        Tu refugio<br />
        <span class="italic text-secondary">sobre las nubes</span>
      </h2>
      <p class="section-subtitle mt-4">
        Tres espacios únicos diseñados para que cada momento sea una experiencia extraordinaria.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {accommodations.map((acc, i) => (
        <article class="group bg-white rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 fade-up" style={`transition-delay: ${i * 150}ms`}>
          <!-- Image -->
          <div class="relative h-64 overflow-hidden">
            <img
              src={acc.image}
              alt={acc.imageAlt}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
            <!-- Capacity badge -->
            <span class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm text-primary text-xs font-semibold px-3 py-1.5 rounded-full">
              {acc.capacity}
            </span>
          </div>

          <!-- Content -->
          <div class="p-8">
            <h3 class="text-2xl font-heading font-bold text-primary mb-1">
              {acc.name}
            </h3>
            <p class="text-gold text-sm font-medium italic mb-4">{acc.tagline}</p>
            <p class="text-primary/70 leading-relaxed mb-6">{acc.description}</p>

            <!-- Features -->
            <ul class="space-y-2 mb-8">
              {acc.features.map((feature) => (
                <li class="flex items-center gap-2 text-sm text-primary/70">
                  <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <a href={acc.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary w-full justify-center">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Reservar ahora
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
