---
---

<section id="ubicacion" class="section-padding bg-light">
  <div class="max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Info -->
      <div class="fade-up">
        <span class="text-secondary text-sm font-semibold tracking-[0.25em] uppercase mb-4 block">
          Ubicación
        </span>
        <h2 class="section-title !text-left">
          Cómo llegar a<br />
          <span class="italic text-secondary">las nubes</span>
        </h2>

        <div class="space-y-6 mt-8">
          <!-- From Medellín -->
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-primary text-lg">Desde Medellín</h3>
              <p class="text-primary/70 mt-1">Aproximadamente 2 horas por la autopista Medellín-Bogotá. Toma la salida hacia Granada y sigue las indicaciones hacia la zona rural.</p>
            </div>
          </div>

          <!-- From Granada -->
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-primary text-lg">Desde Granada</h3>
              <p class="text-primary/70 mt-1">A solo 15 minutos del casco urbano de Granada. Se recomienda vehículo alto o 4x4 para el último tramo.</p>
            </div>
          </div>

          <!-- Altitude -->
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15l5-5 4 4 8-8M17 7h4v4" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-primary text-lg">Altitud y clima</h3>
              <p class="text-primary/70 mt-1">Ubicado a 2,200 m.s.n.m. con una temperatura promedio de 14-18°C. Te recomendamos traer ropa abrigada y disfrutar del clima de montaña.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="fade-up">
        <div class="rounded-3xl overflow-hidden shadow-2xl aspect-square md:aspect-[4/3]">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d63452.79693553087!2d-75.18!3d6.145!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e46916e1edbc0c7%3A0x4f2f4f5c8e8b8e4a!2sGranada%2C%20Antioquia!5e0!3m2!1ses!2sco!4v1700000000000!5m2!1ses!2sco"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Entrenubes Glamping en Granada, Antioquia"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
